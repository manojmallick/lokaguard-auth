# ── Auth0 Core ─────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=...
AUTH0_CLIENT_SECRET=...
AUTH0_AUDIENCE=https://your-tenant.us.auth0.com/api/v2/

# ── Token Vault ────────────────────────────────────────────
# Base URL for Token Vault REST calls
AUTH0_TOKEN_VAULT_BASE_URL=https://your-tenant.us.auth0.com
# Service account user ID whose connected accounts to use
AUTH0_SERVICE_ACCOUNT_USER_ID=auth0|...

# ── CIBA (Client-Initiated Backchannel Authentication) ─────
AUTH0_CIBA_CLIENT_ID=...
AUTH0_CIBA_CLIENT_SECRET=...
# Shown on CISO's phone during approval — include report ID at runtime
CIBA_BINDING_MESSAGE_PREFIX="LokaGuard: Approve DORA submission"

# ── OpenFGA ────────────────────────────────────────────────
OPENFGA_API_URL=https://api.us1.fga.dev
OPENFGA_STORE_ID=...
OPENFGA_AUTHORIZATION_MODEL_ID=...
OPENFGA_API_TOKEN=...

# ── Local LLM ──────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
# Use qwen2.5:7b for development, qwen2.5:14b for demo
OLLAMA_MODEL=qwen2.5:7b

# ── Database ───────────────────────────────────────────────
DATABASE_PATH=./data/lokaguard.db

# ── External services ──────────────────────────────────────
# Set to mock URL for hackathon demo (docker-compose includes mock)
DNB_API_BASE_URL=http://localhost:8080/dnb-mock/v1
DNB_ORG_LEI=724500AB12CD34EF5678

# ── GitHub (for audit trail) ───────────────────────────────
# Used via Token Vault — do NOT put real tokens here
GITHUB_AUDIT_REPO=lokaguard-audit-trail
GITHUB_AUDIT_OWNER=your-github-username

# ── GitHub PAT (optional — hackathon shortcut) ─────────────
# If set, AuditAgent uses this instead of Token Vault for GitHub writes.
# Useful when Token Vault GitHub connection is not yet configured.
# Leave blank (or omit) in production — use Token Vault instead.
GITHUB_PAT=

# ── App ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# ── Demo mode (set to "true" to bypass real Auth0/OpenFGA calls) ──
DEMO_MODE=true
