{
  "name": "lokaguard-auth",
  "version": "1.0.0",
  "description": "DORA Article 19 ICT incident reporting automation with Auth0 Token Vault, CIBA, and OpenFGA",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@auth0/ai": "latest",
    "auth0": "^4.0.0",
    "@openfga/sdk": "^0.6.0",
    "express": "^4.18.2",
    "ws": "^8.14.2",
    "better-sqlite3": "^9.4.3",
    "zod": "^3.22.4",
    "ollama": "^0.5.0",
    "winston": "^3.11.0",
    "jose": "^5.2.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "tsx": "^4.7.0",
    "ts-node-dev": "^2.0.0",
    "vitest": "^1.0.0",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.10",
    "@types/better-sqlite3": "^7.6.8",
    "@types/uuid": "^9.0.7"
  }
}
